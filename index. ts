function spawnWoodLogAt(x: number, z: number) {
  const log = new THREE.Mesh(woodGeo, woodMat);
  log.rotation.z = Math.PI / 2; 
  log.position.set(x + Math.random() * 1.5 - 0.75, 0.15, z + Math.random() * 1.5 - 0.75);
