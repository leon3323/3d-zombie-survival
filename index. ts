// -------------------------------------------------------------------
// CHARACTER BUILDER ENGINE
// -------------------------------------------------------------------
class GameCharacter {
  group: THREE.Group;
  head!: THREE.Group;
  body!: THREE.Group;
  arms: THREE.Group[] = [];
  legs: THREE.Group = new THREE.Group();
  bodyMaterial!: THREE.MeshStandardMaterial;
  headMaterial!: THREE.MeshStandardMaterial;
  type: string;

  constructor(type: string) {
    this.group = new THREE.Group();
    this.type = type;
    this.initColors();
    this.initGeometry();
    scene.add(this.group);
  }

  initColors() {
    if (this.type === 'player') {
      this.headMaterial = new THREE.MeshStandardMaterial({ color: 0xffdbac, roughness: 0.4 });
      this.bodyMaterial = new THREE.MeshStandardMaterial({ color: 0x00d2ff, roughness: 0.4 });
    } else if (this.type === 'runner') {
      this.bodyMaterial = new THREE.MeshStandardMaterial({ color: 0x8800aa, roughness: 0.5 }); 
      this.headMaterial = new THREE.MeshStandardMaterial({ color: 0x44aa77, roughness: 0.6 });
    } else if (this.type === 'tank') {
      this.bodyMaterial = new THREE.MeshStandardMaterial({ color: 0x112244, roughness: 0.4 }); 
      this.headMaterial = new THREE.MeshStandardMaterial({ color: 0x226633, roughness: 0.5 });
    } else {
      this.bodyMaterial = new THREE.MeshStandardMaterial({ color: 0xaa0000, roughness: 0.5 }); 
      this.headMaterial = new THREE.MeshStandardMaterial({ color: 0x55aa55, roughness: 0.6 });
    }
  }

  initGeometry() {
    let bW = 0.8, bH = 1.2, bD = 0.6, hS = 1.0;
    if (this.type === 'tank') { bW = 1.6; bH = 2.0; bD = 1.2; hS = 1.5; }
    if (this.type === 'runner') { bW = 0.6; bH = 1.0; bD = 0.5; hS = 0.8; }

    this.body = new THREE.Group();
    const bodyMain = new THREE.Mesh(new THREE.BoxGeometry(bW, bH, bD), this.bodyMaterial);
    this.body.add(bodyMain);
    this.group.add(this.body);
    this.body.position.y = bH / 2 + 0.2;

    this.head = new THREE.Group();
    const headMain = new THREE.Mesh(new THREE.BoxGeometry(hS, hS, hS), this.headMaterial);
    this.head.add(headMain);
    this.group.add(this.head);
    this.head.position.y = bH + (hS / 2) + 0.2;

    const eyeGeo = new THREE.SphereGeometry(0.08 * hS, 8, 8);
    const eyeMat = new THREE.MeshStandardMaterial({ color: this.type === 'player' ? 0x111111 : 0xff0000 });
    for (let i = 0; i < 2; i++) {
      const eye = new THREE.Mesh(eyeGeo, eyeMat);
      eye.position.set(0.25 * hS * isEvenOrOdd(i), 0, hS / 2 + 0.02);
      this.head.add(eye);
    }

    const armGeo = new THREE.BoxGeometry(0.2 * hS, 0.7 * bH, 0.2 * hS);
    for (let i = 0; i < 2; i++) {
      const armGroup = new THREE.Group();
      const arm = new THREE.Mesh(armGeo, this.headMaterial);
      arm.position.y = -(0.7 * bH) / 2;
      armGroup.add(arm);
      this.arms.push(armGroup);
      this.group.add(armGroup);
      armGroup.position.set(isEvenOrOdd(i) * (bW / 2 + 0.15), bH + 0.1, 0);
      if (this.type !== 'player') armGroup.rotation.x = degreesToRadians(-90);
    }

    const legGeo = new THREE.BoxGeometry(0.2 * hS, 0.4 * bH, 0.2 * hS);
    for (let i = 0; i < 2; i++) {
      const leg = new THREE.Mesh(legGeo, this.bodyMaterial);
      leg.position.x = isEvenOrOdd(i) * (bW / 4);
      this.legs.add(leg);
    }
    this.legs.position.y = 0.2;
    this.body.add(this.legs);
  }
}

