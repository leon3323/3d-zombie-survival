// --- OPERATION INTERFACES ---
const raycaster = new THREE.Raycaster();
const mouse = new THREE.Vector2();
let targetAimPoint = new THREE.Vector3();
let lastDirection = new THREE.Vector3(0, 0, -1);

window.addEventListener('mousemove', (e) => {
  mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
  mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
});

const keys = { w: false, a: false, s: false, d: false };
window.addEventListener('keydown', (e) => {
  if (isPaused || isGameOver) return;
  const k = e.key.toLowerCase();
  if (k in keys) keys[k] = true;
  
  if (k === '1') { currentWeapon = 'pistol'; updateHUD(); }
  if (k === '2' && unlockedWeapons.shotgun) { currentWeapon = 'shotgun'; updateHUD(); }
  if (k === '3' && unlockedWeapons.machinegun) { currentWeapon = 'machinegun'; updateHUD(); }

  if (k === 'e' && player.position.length() < baseRadius && heldWoodCount > 0 && baseHealth < 100) {
    heldWoodCount--; baseHealth = Math.min(100, baseHealth + 20); updateHUD();
    (safeBase.material as THREE.MeshStandardMaterial).color.setHex(0x995522);
    setTimeout(() => { if (!isBaseDestroyed) (safeBase.material as THREE.MeshStandardMaterial).color.setHex(0x00ffaa); }, 150);
  }
});
window.addEventListener('keyup', (e) => { const k = e.key.toLowerCase(); if (k in keys) keys[k] = false; });

// SHOOTING ROUTINE
window.addEventListener('click', (e) => {
  // Prevent shooting action checks if clicking the Pause overlay button itself
  if (e.clientX > window.innerWidth - 120 && e.clientY < 60) return;
  if (isGameOver || isPaused) return;

  const now = performance.now();
  const stats = weaponStats[currentWeapon];
  if (now - lastShotTime < stats.delay) return; 
  lastShotTime = now;

  const shootPos = player.position.clone(); shootPos.y = 1.0;
  const baseDir = new THREE.Vector3().subVectors(targetAimPoint, shootPos);
  baseDir.y = 0; baseDir.normalize();

  stats.spreads.forEach(spreadAngle => {
    const fireDirection = baseDir.clone().applyAxisAngle(new THREE.Vector3(0, 1, 0), spreadAngle);
    
    const mat = new THREE.LineBasicMaterial({ color: 0xffff00 });
    const points = [shootPos, shootPos.clone().addScaledVector(fireDirection, stats.range)];
    const geo = new THREE.BufferGeometry().setFromPoints(points);
    const line = new THREE.Line(geo, mat);
    scene.add(line);
    setTimeout(() => scene.remove(line), 60);

    // 🌳 CHOP TREES TEST
    trees.forEach((tree, tIdx) => {
      const pToTree = new THREE.Vector3().subVectors(tree.group.position, player.position);
      if (pToTree.length() < stats.range) {
        if (fireDirection.angleTo(pToTree.normalize()) < 0.25) {
          tree.health--;
          (tree.trunk.material as THREE.MeshStandardMaterial).color.setHex(0xffffff); 
          setTimeout(() => (tree.trunk.material as THREE.MeshStandardMaterial).color.setHex(0x5a3d28), 60);
          
          if (tree.health <= 0) {
            for (let k = 0; k < 3; k++) spawnWoodLogAt(tree.group.position.x, tree.group.position.z);
            scene.remove(tree.group);
            trees.splice(tIdx, 1);
            spawnTree(); 
          }
        }
      }
    });

    // 🧟 HIT ZOMBIES TEST
    zombies.forEach((zombie, zIdx) => {
      const pToZombie = new THREE.Vector3().subVectors(zombie.character.group.position, player.position);
      if (pToZombie.length() < stats.range) {
        if (fireDirection.angleTo(pToZombie.normalize()) < 0.22) {
          zombie.health--;
          
          const mainTorso = zombie.character.body.children[0] as THREE.Mesh;
          const oldColor = mainTorso.material.color.getHex();
          (mainTorso.material as THREE.MeshStandardMaterial).color.setHex(0xffffff);
          setTimeout(() => (mainTorso.material as THREE.MeshStandardMaterial).color.setHex(oldColor), 60);

          if (zombie.health <= 0) {
            const zX = zombie.character.group.position.x;
            const zZ = zombie.character.group.position.z;
            
            if (zombie.character.type === 'runner') {
              spawnWeaponDrop(zX, zZ, 'shotgun');
            } else if (zombie.character.type === 'tank') {
              spawnWeaponDrop(zX, zZ, 'machinegun');
            }

            scene.remove(zombie.character.group);
            zombies.splice(zIdx, 1);
            score++; updateHUD();
          }
        }
      }
    });
  });
});

const playerSpeed = 0.12;
let animationTimer = 0;

// -------------------------------------------------------------------
// RUNTIME TICK LOOP ENGINE
// -------------------------------------------------------------------
function animate() {
  requestAnimationFrame(animate);
  
  // 🛑 PAUSE BLOCK ENFORCEMENT
  if (isPaused || isGameOver) {
    renderer.render(scene, camera); // Render the frozen frame scene state statically
    return; 
  }

  animationTimer += 0.2;
  const currentTime = performance.now();

  // Mouse Raycast Aiming
  raycaster.setFromCamera(mouse, camera);
  const intersects = raycaster.intersectObject(ground);
  if (intersects.length > 0) {
    targetAimPoint.copy(intersects[0].point);
    player.rotation.y = Math.atan2(targetAimPoint.x - player.position.x, targetAimPoint.z - player.position.z);
    lastDirection.set(targetAimPoint.x - player.position.x, 0, targetAimPoint.z - player.position.z).normalize();
  }

  // WASD Movement Operations
  const moveDir = new THREE.Vector3(0, 0, 0);
  if (keys.w) moveDir.z -= 1; if (keys.s) moveDir.z += 1;
  if (keys.a) moveDir.x -= 1; if (keys.d) moveDir.x += 1;

  if (moveDir.lengthSq() > 0) {
    moveDir.normalize();
    const prevX = player.position.x; const prevZ = player.position.z;
    player.position.addScaledVector(moveDir, playerSpeed);

    playerCharacter.legs.children.forEach((leg, i) => leg.rotation.x = Math.sin(animationTimer) * 0.6 * isEvenOrOdd(i));
    playerCharacter.arms.forEach((arm, i) => arm.rotation.x = Math.cos(animationTimer) * 0.4 * isEvenOrOdd(i));

    obstacles.forEach(wall => {
      if (Math.abs(player.position.x - wall.position.x) < 2.2 && Math.abs(player.position.z - wall.position.z) < 2.2) {
        player.position.x = prevX; player.position.z = prevZ;
      }
    });
  } else {
    playerCharacter.legs.children.forEach(leg => leg.rotation.x = 0);
    playerCharacter.arms.forEach(arm => arm.rotation.x = 0);
  }

  // Log Resource Pickup Processing
  woodLogs.forEach((log, index) => {
    if (player.position.distanceTo(log.position) < 1.2) {
      scene.remove(log); woodLogs.splice(index, 1);
      heldWoodCount++; updateHUD();
    }
  });

  // WEAPON CRATE PICKUP DETECTION
  droppedWeapons.forEach((drop, index) => {
    drop.mesh.rotation.y += 0.04;
    drop.mesh.rotation.x += 0.02;

    if (player.position.distanceTo(drop.mesh.position) < 1.4) {
      if (drop.type === 'shotgun') unlockedWeapons.shotgun = true;
      if (drop.type === 'machinegun') unlockedWeapons.machinegun = true;
      currentWeapon = drop.type;
      
      scene.remove(drop.mesh);
      droppedWeapons.splice(index, 1);
      updateHUD();
    }
  });

  // Base Safe Zone Health Regen
  if (player.position.length() < baseRadius && !isBaseDestroyed && playerHealth < 3 && currentTime - lastHealTime > 3000) {
    playerHealth++; lastHealTime = currentTime; updateHUD();
  }

  // Zombie Movement Intelligence
  zombies.forEach(zombie => {
    const zGroup = zombie.character.group;
    const zombieDir = new THREE.Vector3().subVectors(player.position, zGroup.position);
    zombieDir.y = 0; 
    const distanceToPlayer = zombieDir.length();
    const zombieDistanceFromCenter = zGroup.position.length();
    zombieDir.normalize();
    
    if (!isBaseDestroyed && zombieDistanceFromCenter <= baseRadius + 0.1 && player.position.length() < baseRadius) {
      baseHealth -= zombie.type === 'tank' ? 0.25 : 0.08; 
      updateHUD();
      zGroup.position.setLength(baseRadius + 0.2);
      
      const mainTorso = zombie.character.body.children[0] as THREE.Mesh;
      mainTorso.material.color.setHex(0xffaa00); 

      if (baseHealth <= 0) {
        isBaseDestroyed = true; scene.remove(safeBase); scene.remove(baseRing); updateHUD();
      }
    } else {
      zGroup.position.addScaledVector(zombieDir, zombie.speed);
      const mainTorso = zombie.character.body.children[0] as THREE.Mesh;
      if (mainTorso) {
        if (zombie.type === 'runner') mainTorso.material.color.setHex(0x8800aa);
        else if (zombie.type === 'tank') mainTorso.material.color.setHex(0x112244);
        else mainTorso.material.color.setHex(0xaa0000);
      }
    }

    zGroup.rotation.y = Math.atan2(zombieDir.x, zombieDir.z);
    zombie.character.legs.children.forEach((leg, i) => leg.rotation.x = Math.sin(animationTimer * 0.7) * 0.3 * isEvenOrOdd(i));

    // Player Combat Collision Check
    if (distanceToPlayer < (zombie.type === 'tank' ? 1.6 : 1.1)) {
      if (currentTime - lastDamageTime > 1000) {
        playerHealth--; lastDamageTime = currentTime; updateHUD();
        damageFlash.style.backgroundColor = 'rgba(255, 0, 0, 0.4)';
        setTimeout(() => { damageFlash.style.backgroundColor = 'rgba(255, 0, 0, 0)'; }, 100);
        if (playerHealth <= 0) { isGameOver = true; finalScore.innerText = `You defended your base and eliminated ${score} zombies!`; gameOverScreen.style.display = 'flex'; }
      }
    }
  });

  camera.position.x = player.position.x;
  camera.position.z = player.position.z + 7;
  camera.lookAt(player.position);

  renderer.render(scene, camera);
}

animate();
updateHUD();

window.addEventListener('resize', () => {
  sizes.width = window.innerWidth; sizes.height = window.innerHeight;
  camera.aspect = sizes.width / sizes.height; camera.updateProjectionMatrix();
  renderer.setSize(sizes.width, sizes.height);
});
