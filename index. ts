  const leavesMat = new THREE.MeshStandardMaterial({ color: 0x1A5F1A, roughness: 0.8 });
  const leaves = new THREE.Mesh(leavesGeo, leavesMat);
  leaves.position.y = 3.5;
  treeGroup.add(leaves);
  
  treeGroup.position.set(random(-28, 28), 0, random(-28, 28));
  if (treeGroup.position.length() < baseRadius + 4) treeGroup.position.setLength(baseRadius + 6);
  
  scene.add(treeGroup);
  trees.push({ group: treeGroup, trunk: trunk, health: 5 });
}

