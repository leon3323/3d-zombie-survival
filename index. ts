function restartGame() {
  zombies.forEach(z => scene.remove(z.character.group)); zombies = [];
  woodLogs.forEach(log => scene.remove(log)); woodLogs.length = 0;
  trees.forEach(t => scene.remove(t.group)); trees.length = 0;
  droppedWeapons.forEach(w => scene.remove(w.mesh)); droppedWeapons.length = 0;

  score = 0; playerHealth = 3; baseHealth = 100; heldWoodCount = 0; isBaseDestroyed = false; currentWeapon = 'pistol';
  unlockedWeapons.shotgun = false; unlockedWeapons.machinegun = false;
  player.position.set(0, 0, 0); isGameOver = false; isPaused = false;
  
  pauseBtn.innerText = '⏸️ PAUSE';
  pauseBtn.style.backgroundColor = '#333333';
  pauseBtn.style.borderColor = '#555555';

  scene.add(safeBase); scene.add(baseRing);
  for (let i = 0; i < 6; i++) spawnTree();
  for (let i = 0; i < 3; i++) spawnWoodLogAt(random(-15, 15), random(-15, 15));

  updateHUD();
  gameOverScreen.style.display = 'none';
  spawnZombieHorde(); spawnZombieHorde();
}

// --- HORDE GENERATOR REGISTRY ---
function spawnZombieHorde() {
  if (isGameOver || isPaused) return; // Prevent spawns during freezes
  
  const roll = Math.random();
  let type = 'normal'; let hp = 3; let speed = 0.025;
  
  if (roll < 0.25) { type = 'runner'; hp = 1; speed = 0.055; } 
  else if (roll > 0.85) { type = 'tank'; hp = 12; speed = 0.012; } 
  
  const zombie = new GameCharacter(type);
  const zMesh = zombie.group;
  const angle = Math.random() * Math.PI * 2;
  const distance = 26 + Math.random() * 6;
  
  zMesh.position.set(player.position.x + Math.cos(angle) * distance, 0, player.position.z + Math.sin(angle) * distance);
  zombies.push({ character: zombie, health: hp, maxHp: hp, speed: speed });
}

spawnZombieHorde(); spawnZombieHorde();
